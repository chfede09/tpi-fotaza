doctype html
html(lang="es")
    head
        meta(charset="UTF-8")
        title #{title}
        style.
            body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; background-color: #fafafa; color: #262626; }
            .navbar { background-color: white; border-bottom: 1px solid #dbdbdb; padding: 10px 20px; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 100; }
            .navbar h1 { margin: 0; font-size: 24px; color: #333; }
            .nav-links a { text-decoration: none; color: #0095f6; font-weight: bold; margin-left: 20px; }
            .nav-links a.logout { color: #ed4956; }
            .feed-container { max-width: 600px; margin: 30px auto; padding: 0 10px; }
            .btn-nueva { display: block; text-align: center; background-color: #0095f6; color: white; padding: 10px; border-radius: 4px; text-decoration: none; font-weight: bold; margin-bottom: 20px; }
            .btn-nueva:hover { background-color: #0077cc; }
            .post-card { background: white; border: 1px solid #dbdbdb; border-radius: 3px; margin-bottom: 30px; }
            .post-header { padding: 14px; font-weight: bold; display: flex; align-items: center; border-bottom: 1px solid #efefef; }
            .post-img { width: 100%; height: auto; max-height: 500px; object-fit: cover; display: block; }
            .post-body { padding: 14px; border-bottom: 1px solid #efefef; }
            .post-title { font-size: 16px; margin: 0 0 8px 0; font-weight: bold; }
            .post-desc { margin: 0; color: #4a4a4a; line-height: 1.4; }
            .post-date { font-size: 12px; color: #8e8e8e; text-transform: uppercase; margin-top: 10px; }
            .comments-section { padding: 14px; background-color: #fbfbfb; }
            .comment-item { margin-bottom: 8px; font-size: 14px; }
            .comment-user { font-weight: bold; margin-right: 6px; }
            .comment-form { display: flex; margin-top: 10px; }
            .comment-input { flex-grow: 1; padding: 8px; border: 1px solid #dbdbdb; border-radius: 4px 0 0 4px; outline: none; }
            .comment-btn { padding: 8px 14px; background-color: #0095f6; color: white; border: none; border-radius: 0 4px 4px 0; cursor: pointer; font-weight: bold; }
            .no-posts { text-align: center; color: #8e8e8e; margin-top: 50px; }
    body
        nav.navbar
            h1 Fotaza 📸
            .nav-links
                if usuarioLogueado
                    span Bienvenido, #[strong #{username}] (<i>#{role}</i>)
                    a(href="/publicaciones/mis-fotos") 🗂️ Mis Fotos
                    a(href="/publicaciones/nueva") ➕ Subir Foto
                    a.logout(href="/auth/logout") Cerrar Sesión
                else
                    a(href="/auth/login") Iniciar Sesión
                    a(href="/auth/register") Registrarse

        .feed-container
            if usuarioLogueado
                a.btn-nueva(href="/publicaciones/nueva") ¡Compartí una nueva foto con la comunidad!

            if publicaciones && publicaciones.length > 0
                each post in publicaciones
                    .post-card
                        .post-header
                            span 👤 @#{post.username}
                        img.post-img(src=post.url_imagen alt=post.titulo)
                        .post-body
                            h3.post-title= post.titulo
                            p.post-desc= post.descripcion
                            .post-date Subido el: #{new Date(post.fecha_creacion).toLocaleDateString('es-AR')}
                        
                        .comments-section
                            if post.comentarios && post.comentarios.length > 0
                                each com in post.comentarios
                                    .comment-item
                                        span.comment-user @#{com.username}:
                                        span= com.contenido
                            else
                                p(style="color: #8e8e8e; margin: 0; font-size: 13px;") No hay comentarios aún.

                            if usuarioLogueado
                                form.comment-form(action="/publicaciones/comentario" method="POST")
                                    input(type="hidden" name="publicacion_id" value=post.id)
                                    input.comment-input(type="text" name="contenido" placeholder="Escribe un comentario..." required)
                                    button.comment-btn(type="submit") Publicar
            else
                .no-posts
                    h3 No hay publicaciones todavía.
                    p ¡Sé el primero en subir una foto!